{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "make",
            "type": "shell",
            "command": "../gnb --no-gen ${command:zmk.getTargetConfig} -- ${command:zmk.getNinjaTarget}",
            "options": {
                "cwd": "${command:zmk.getBuildDir}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "base": "$gcc",
                "fileLocation": [ "relative", "${command:zmk.getBuildDir}" ]
            },
            "presentation": {
                "clear": true
            },
        },
        {
            "label": "Compile current file",
            "type": "shell",
            "command": "../gnb --no-gen ${command:zmk.getTargetConfig} -- ${command:zmk.getCurrentFile}^",
            "options": {
                "cwd": "${command:zmk.getBuildDir}"
            },
            "problemMatcher": {
                "base": "$gcc",
                "fileLocation": [ "relative", "${command:zmk.getBuildDir}" ]
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "make symbols",
            "type": "shell",
            "command": "../gnb --no-gen ${command:zmk.getTargetConfig} -- generate_symbols",
            "options": {
                "cwd": "${command:zmk.getBuildDir}"
            },
            // "group": {
            //     "kind": "build",
            //     "isDefault": true
            // },
            "problemMatcher": {
                "base": "$gcc",
                "fileLocation": [ "relative", "${command:zmk.getBuildDir}" ]
            },
            "presentation": {
                "clear": true
            },
            // "dependsOn": "pre-clean"
        },
        {
            "label": "refresh ninja",
            "type": "shell",
            "command": "./gnb ${command:zmk.getTargetConfig} -- empty",
            "options": {
                "cwd": "${command:zmk.getRootDir}"
            },
            "problemMatcher": {
                "base": "$gcc",
                "fileLocation": [ "relative", "${command:zmk.getRootDir}" ]
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "build all",
            "type": "shell",
            "command": "./gnb ${command:zmk.getTargetConfig}",
            "options": {
                "cwd": "${command:zmk.getRootDir}"
            },
            "problemMatcher": {
                "base": "$gcc",
                "fileLocation": [ "relative", "${command:zmk.getBuildDir}" ]
            },
        },
        {
            "label": "zebra: Valgrind/Callgrind",
            "type": "shell",
            "options": { "cwd": "${command:zmk.getBuildDir}",
                "env": {
                    "LD_LIBRARY_PATH": "${command:zmk.getBuildDir}/linux/sysroot/usr/lib",
                    "V8_FLAGS": "--max-old-space-size=50",
                    "DFBARGS": "system=x11,module-dir=${command:zmk.getBuildDir}/linux/sysroot/usr/lib/directfb-1.7-8,no-cursor,no-debug,mode=1280x720,depth=32,no-sighandler",
                    "SKIA_FONTS": "${command:zmk.getBuildDir}/linux/sysroot/home/zodiac/fonts",
                    "ZEBRA_POLYFILLS_PATH": "${command:zmk.getBuildDir}/linux/sysroot/home/zodiac/polyfills",
                }
            },
            "command": [ "valgrind", "--tool=callgrind",
                "${command:zmk.getBuildDir}/zebra_mini",
                "--standalone", "http://lets.developonbox.ru/customers/comcast/comcast-x1/proto/"
            ],
            "problemMatcher": {
                "base": "$gcc",
                "fileLocation": [ "relative", "${command:zmk.getBuildDir}" ]
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "zebra: Direct run",
            "type": "shell",
            "options": { "cwd": "${command:zmk.getBuildDir}",
                "env": {
                    "LD_LIBRARY_PATH": "${command:zmk.getBuildDir}/linux/sysroot/usr/lib",
                    "V8_FLAGS": "--max-old-space-size=50",
                    "DFBARGS": "system=x11,module-dir=${command:zmk.getBuildDir}/linux/sysroot/usr/lib/directfb-1.7-8,no-cursor,no-debug,mode=1280x720,depth=32,no-sighandler",
                    "SKIA_FONTS": "${command:zmk.getBuildDir}/linux/sysroot/home/zodiac/fonts",
                    "ZEBRA_POLYFILLS_PATH": "${command:zmk.getBuildDir}/linux/sysroot/home/zodiac/polyfills",
                }
            },
            "command": [
                "${command:zmk.getBuildDir}/zebra_mini",
                "--standalone", "http://lets.developonbox.ru/customers/comcast/comcast-x1/proto/"
            ],
            "problemMatcher": {
                "base": "$gcc",
                "fileLocation": [ "relative", "${command:zmk.getBuildDir}" ]
            },
            "presentation": {
                "clear": true
            }
        }
    ]
}
