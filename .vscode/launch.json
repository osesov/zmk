// A launch configuration that compiles the extension and then opens it inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				// "/home/osesov/zodiac/valhalla/components/powerup/native/apps/PowerUpJS"
				"${workspaceFolder}/../valhalla"
				// "/home/osesov/zodiac/valhalla".
				// "/home/osesov/zodiac/third-party/uriparser",
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "esbuild"
		},
		{
			"name": "Extension Tests",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"--extensionTestsPath=${workspaceFolder}/out/test"
			],
			"outFiles": [
				"${workspaceFolder}/out/test/**/*.js"
			],
			"preLaunchTask": "npm: watch"
		},

		{
			"name": "scripts/prepare-ninja.mjs",
			"type": "node",
			"request": "launch",
			"program": "${workspaceFolder}/scripts/prepare-ninja.mjs",
			"args": []
		}
	]
}
