{
	"name": "zmk",
	"displayName": "zmk",
	"description": "Zodiac Make",
	"version": "2.6.0",
	"engines": {
		"vscode": "^1.111.0"
	},
	"categories": [
		"Other"
	],
	"publisher": "osesov",
	"repository": {
		"type": "git",
		"url": "https://github.com/osesov/zmk.git"
	},
	"activationEvents": [
		"onLanguage:cpp",
		"workspaceContains:**/BUILD.gn",
		"workspaceContains:**/.gn",
		"onTaskType:gnb",
		"onLanguageModelTool:valhalla-list-configs",
		"onLanguageModelTool:valhalla-build-target"
	],
	"extensionKind": [
		"workspace"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "zmk.updateBundlesInclude",
				"title": "ZMK: Update bundles Include Paths"
			},
			{
				"command": "zmk.updateCopyright",
				"title": "ZMK: Insert or update Copyright header"
			},
			{
				"command": "zmk.setConfig",
				"title": "ZMK: Set Config"
			},
			{
				"command": "zmk.setDefaultConfig",
				"title": "Select Configuration",
				"icon": "$(star-empty)"
			},
			{
				"command": "zmk.openConfig",
				"title": "Open Configuration File",
				"icon": "$(file-code)"
			},
			{
				"command": "zmk.copyConfig",
				"title": "Copy Config Name to Clipboard",
				"icon": "$(copy)"
			},
			{
				"command": "zmk.refreshConfigTree",
				"title": "ZMK: Refresh Configurations",
				"icon": "$(refresh)"
			},
			{
				"command": "zmk.selectAndBuildTarget",
				"title": "ZMK: Build"
			},
			{
				"command": "zmk.selectAndRunTest",
				"title": "ZMK: Run Test"
			},
			{
				"command": "zmk.buildTarget",
				"title": "Build",
				"icon": "$(play)"
			},
			{
				"command": "zmk.openTarget",
				"title": "Open Target Build File",
				"icon": "$(file-code)"
			},
			{
				"command": "zmk.setDefaultTarget",
				"title": "Set as Default",
				"icon": "$(star-empty)"
			},
			{
				"command": "zmk.copyTarget",
				"title": "Copy Target Name to Clipboard",
				"icon": "$(copy)"
			},
			{
				"command": "zmk.addToBrowseSet",
				"title": "Add to Browse Set",
				"icon": "$(diff-added)"
			},
			{
				"command": "zmk.removeFromBrowseSet",
				"title": "Remove from Browse Set",
				"icon": "$(diff-removed)"
			},
			{
				"command": "zmk.resetTarget",
				"title": "Reset Target",
				"icon": "$(discard)"
			},
			{
				"command": "zmk.refreshTargetTree",
				"title": "Refresh Targets",
				"icon": "$(refresh)"
			},
			{
				"command": "zmk.findTarget",
				"title": "Find Target",
				"icon": "$(search)"
			},
			{
				"command": "zmk.goToTargetDep",
				"title": "Go To Target",
				"icon": "$(go-to-file)"
			},
			{
				"command": "zmk.openSourceFile",
				"title": "Open File",
				"icon": "$(file-code)"
			},
			{
				"command": "zmk.revealIncludeDirInExplorer",
				"title": "Reveal in Explorer View",
				"icon": "$(file-directory)"
			},
			{
				"command": "zmk.openIncludeDirFolder",
				"title": "Open Containing Folder",
				"icon": "$(folder-opened)"
			},
			{
				"command": "zmk.sourceTree.revealSourceInExplorer",
				"title": "Reveal in Explorer View",
				"icon": "$(file-directory)"
			},
			{
				"command": "zmk.sourceTree.revealSourceInOS",
				"title": "Open Containing Folder",
				"icon": "$(folder-opened)"
			},
			{
				"command": "zmk.copyPropertyValue",
				"title": "Copy Value",
				"icon": "$(copy)"
			},
			{
				"command": "zmk.copyArgValue",
				"title": "Copy Arg Value",
				"icon": "$(copy)"
			},
			{
				"command": "zmk.copyArgPair",
				"title": "Copy Arg as name=value",
				"icon": "$(copy)"
			},
			{
				"command": "zmk.copyTargetData",
				"title": "Copy Target Data as JSON",
				"icon": "$(json)"
			},
			{
				"command": "zmk.toggleIncludeListView",
				"title": "Show Includes as list",
				"icon": "$(list-unordered)"
			},
			{
				"command": "zmk.toggleIncludeTreeView",
				"title": "Show Includes as tree",
				"icon": "$(list-tree)"
			},
			{
				"command": "zmk.revealIncludeInExplorer",
				"title": "Reveal in Explorer View",
				"icon": "$(file-directory)"
			},
			{
				"command": "zmk.revealIncludeInOS",
				"title": "Open Containing folder",
				"icon": "$(file-directory)"
			},
			{
				"command": "zmk.review.apply",
				"title": "Apply Reviewed Changes",
				"icon": "$(check)"
			},
			{
				"command": "zmk.review.keepOriginal",
				"title": "Keep Original",
				"icon": "$(close)"
			},
			{
				"command": "zmk.cppSource.copyText",
				"title": "Copy as text",
				"icon": "$(copy)"
			},
			{
				"command": "zmk.cppSource.copyJson",
				"title": "Copy as json",
				"icon": "$(copy)"
			}
		],
		"configuration": {
			"title": "zmk",
			"properties": {
				"zmk.rootDir": {
					"type": "string",
					"default": null,
					"description": "zmk root folder."
				},
				"zmk.buildDir": {
					"type": "string",
					"default": null,
					"description": "zmk root folder."
				},
				"zmk.bundleDir": {
					"type": "string",
					"description": "zmk bundle folder location",
					"default": null
				},
				"zmk.config": {
					"type": "string",
					"default": "zodiac-pc_linux-zebra-dev",
					"description": "zmk config name."
				},
				"zmk.target": {
					"type": [
						"string",
						"null"
					],
					"default": null,
					"description": "Ninja target to build."
				},
				"zmk.browseTargets": {
					"type": "array",
					"items": {
						"type": "string",
						"title": "target to browse in target tree view"
					},
					"default": [],
					"description": "List of targets to browse. If empty, all targets will be used."
				},
				"zmk.testConfig": {
					"type": "string",
					"default": null,
					"description": "zmk config name for testing (used in test tasks)."
				},
				"zmk.testTarget": {
					"type": [
						"string",
						"null"
					],
					"default": null,
					"description": "ninja target to test."
				},
				"zmk.nfsDir": {
					"type": [
						"string",
						"null"
					],
					"default": null,
					"description": "root of nfs image"
				},
				"zmk.excludeBundles": {
					"type": "array",
					"items": {
						"type": "string",
						"title": "bundle name to exclude"
					},
					"default": [],
					"description": "List of bundles to exclude"
				},
				"zmk.developer": {
					"type": "string",
					"default": "<<<add your name to 'zmk.developer'>>>",
					"description": "Developer name"
				},
				"zmk.copyrightComment": {
					"type": [
						"string",
						null
					],
					"default": null,
					"description": "Copyright comment template"
				},
				"zmk.disableCppToolsIntegration": {
					"type": "boolean",
					"description": "Disable C++ tools integration (include paths, defines, etc.). Use plain C++ tools configs.",
					"default": false
				},
				"zmk.includeDirs": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Extra include dirs for intellisense",
					"default": []
				},
				"zmk.defines": {
					"type": "object",
					"description": "Extra defines for intellisense",
					"additionalProperties": {
						"oneOf": [
							{
								"type": "string"
							},
							{
								"type": "null"
							}
						]
					},
					"default": {}
				},
				"zmk.compiler": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Intellisense compiler path and args",
					"default": []
				},
				"zmk.intelliSenseMode": {
					"type": "string",
					"markdownDescription": "Intellisense mode (e.g. 'gcc-x64'). See [VS Code C++ Intellisense Configuration](https://code.visualstudio.com/docs/cpp/customize-cpp-settings#_configuration-properties)",
					"default": null
				},
				"zmk.cppStandard": {
					"type": "string",
					"markdownDescription": "C++ standard (e.g. 'c++17'). See [VS Code C++ Intellisense Configuration](https://code.visualstudio.com/docs/cpp/customize-cpp-settings#_configuration-properties)",
					"default": null
				},
				"zmk.toolchain": {
					"type": "array",
					"description": "Toolchain selection rules.",
					"items": {
						"type": "object",
						"properties": {
							"pattern": {
								"type": "string",
								"description": "Pattern to match compiler name. 'cross_cpu[-cross_os[-cross_abi]]'"
							},
							"compiler": {
								"type": "array",
								"items": {
									"type": "string"
								},
								"description": "Intellisense compiler path and args"
							},
							"intelliSenseMode": {
								"type": "string",
								"description": "Intellisense mode (e.g. 'gcc-x64'). See [VS Code C++ Intellisense Configuration](https://code.visualstudio.com/docs/cpp/customize-cpp-settings#_configuration-properties)"
							},
							"cppStandard": {
								"type": "string",
								"description": "C++ standard (e.g. 'c++17'). See [VS Code C++ Intellisense Configuration](https://code.visualstudio.com/docs/cpp/customize-cpp-settings#_configuration-properties)"
							},
							"defines": {
								"type": "object",
								"description": "Defines for intellisense",
								"additionalProperties": {
									"oneOf": [
										{
											"type": "string"
										},
										{
											"type": "null"
										}
									]
								}
							},
							"includeDirs": {
								"type": "array",
								"description": "Include dirs for intellisense",
								"items": {
									"type": "string"
								},
								"default": null
							},
							"env": {
								"type": "object",
								"description": "Environment variables for intellisense",
								"additionalProperties": {
									"oneOf": [
										{
											"type": "string"
										},
										{
											"type": "null"
										}
									]
								}
							}
						}
					}
				},
				"zmk.nexusServer": {
					"type": "string",
					"description": "Nexus server URL for docker registry",
					"default": "https://nexus.dev.zodiac.tv:5000"
				}
			}
		},
		"problemMatchers": [
			{
				"name": "gnb-gcc",
				"source": "gnb",
				"base": "$gcc",
				"owner": "gnb",
				"fileLocation": [
					"autoDetect",
					"${command:zmk.getBuildDir}"
				]
			}
		],
		"taskDefinitions": [
			{
				"type": "gnb",
				"properties": {
					"label": {
						"type": "string",
						"description": "Task label"
					},
					"command": {
						"type": "array",
						"items": {
							"type": "string",
							"title": "command part"
						},
						"description": "Command to execute instead of gnb (for debugging)"
					},
					"mode": {
						"type": "string",
						"enum": [
							"build",
							"clean",
							"deep-clean",
							"build-all",
							"build-minimal",
							"build-current-file",
							"test"
						],
						"description": "Build mode"
					},
					"config": {
						"type": "string",
						"description": "gnb config (see configs/*.yaml)"
					},
					"target": {
						"type": "string",
						"description": "ninja target to build"
					},
					"gnbFlags": {
						"type": "array",
						"items": {
							"type": "string",
							"title": "gnb flag"
						},
						"description": "additional gnb flags"
					},
					"gnFlags": {
						"type": "array",
						"items": {
							"type": "string",
							"title": "gn flag"
						},
						"description": "additional gn flags"
					},
					"env": {
						"type": "object",
						"description": "Environment variables",
						"additionalProperties": {
							"oneOf": [
								{
									"type": "string"
								},
								{
									"type": "null"
								}
							]
						}
					}
				}
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "valhallaContainer",
					"title": "Valhalla build system",
					"icon": "./images/helm.svg",
					"dark": "./images/helm.svg"
				}
			]
		},
		"views": {
			"valhallaContainer": [
				{
					"id": "configTreeView",
					"name": "Configurations"
				},
				{
					"id": "targetTreeView",
					"name": "Targets"
				},
				{
					"id": "sourceTreeView",
					"name": "Source Tree"
				},
				{
					"id": "argsView",
					"name": "Args"
				},
				{
					"id": "cppSourceConfig",
					"name": "Source File Info"
				}
			]
		},
		"menus": {
			"editor/title": [
				{
					"command": "zmk.review.apply",
					"when": "resourceScheme == zmk-review",
					"group": "navigation"
				},
				{
					"command": "zmk.review.keepOriginal",
					"when": "resourceScheme == zmk-review",
					"group": "navigation"
				}
			],
			"view/title": [
				{
					"command": "zmk.refreshConfigTree",
					"when": "view == configTreeView",
					"group": "navigation"
				},
				{
					"command": "zmk.refreshTargetTree",
					"when": "view == targetTreeView",
					"group": "navigation"
				},
				{
					"command": "zmk.findTarget",
					"when": "view == targetTreeView",
					"group": "navigation"
				},
				{
					"command": "zmk.resetTarget",
					"when": "view == targetTreeView && zmk.targetSelected",
					"group": "navigation"
				},
				{
					"command": "zmk.toggleIncludeListView",
					"when": "view == cppSourceConfig && zmk.includeViewMode == 'tree'",
					"group": "navigation"
				},
				{
					"command": "zmk.toggleIncludeTreeView",
					"when": "view == cppSourceConfig && zmk.includeViewMode == 'list'",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "zmk.setDefaultConfig",
					"when": "view == configTreeView && viewItem == config",
					"group": "inline"
				},
				{
					"command": "zmk.setDefaultConfig",
					"when": "view == configTreeView && viewItem == config",
					"group": "navigation"
				},
				{
					"command": "zmk.openConfig",
					"when": "view == configTreeView && (viewItem == config || viewItem == defaultConfig)",
					"group": "navigation"
				},
				{
					"command": "zmk.copyConfig",
					"when": "view == configTreeView && (viewItem == config || viewItem == defaultConfig)",
					"group": "navigation@9"
				},
				{
					"command": "zmk.buildTarget",
					"when": "view == targetTreeView && viewItem =~ /<target>/",
					"group": "inline"
				},
				{
					"command": "zmk.buildTarget",
					"when": "view == targetTreeView && viewItem =~ /<target>/",
					"group": "navigation"
				},
				{
					"command": "zmk.openTarget",
					"when": "view == targetTreeView && viewItem =~ /<target>/",
					"group": "navigation"
				},
				{
					"command": "zmk.copyTarget",
					"when": "view == targetTreeView && viewItem =~ /<target>/",
					"group": "navigation"
				},
				{
					"command": "zmk.setDefaultTarget",
					"when": "view == targetTreeView && viewItem =~ /<target>/ && !(viewItem =~ /<current>/)",
					"group": "inline"
				},
				{
					"command": "zmk.setDefaultTarget",
					"when": "view == targetTreeView && viewItem =~ /<target>/ && !(viewItem =~ /<current>/)",
					"group": "navigation@2"
				},
				{
					"command": "zmk.resetTarget",
					"when": "view == targetTreeView && viewItem =~ /<target>/ && viewItem =~ /<current>/",
					"group": "inline"
				},
				{
					"command": "zmk.resetTarget",
					"when": "view == targetTreeView && viewItem =~ /<target>/ && viewItem =~ /<current>/",
					"group": "navigation@2"
				},
				{
					"command": "zmk.addToBrowseSet",
					"when": "view == targetTreeView && viewItem =~ /<browseable>/ && !(viewItem =~ /<browse>/)",
					"group": "inline@2"
				},
				{
					"command": "zmk.addToBrowseSet",
					"when": "view == targetTreeView && viewItem =~ /<browseable>/ && !(viewItem =~ /<browse>/)",
					"group": "navigation@2"
				},
				{
					"command": "zmk.removeFromBrowseSet",
					"when": "view == targetTreeView && viewItem =~ /<browseable>/ && viewItem =~ /<browse>/",
					"group": "inline@2"
				},
				{
					"command": "zmk.removeFromBrowseSet",
					"when": "view == targetTreeView && viewItem =~ /<browseable>/ && viewItem =~ /<browse>/",
					"group": "navigation@2"
				},
				{
					"command": "zmk.goToTargetDep",
					"when": "view == targetTreeView && viewItem == propertyItem.deps",
					"group": "inline"
				},
				{
					"command": "zmk.goToTargetDep",
					"when": "view == targetTreeView && viewItem == propertyItem.deps",
					"group": "navigation"
				},
				{
					"command": "zmk.goToTargetDep",
					"when": "view == targetTreeView && viewItem == propertyItem.reverse_deps",
					"group": "inline"
				},
				{
					"command": "zmk.goToTargetDep",
					"when": "view == targetTreeView && viewItem == propertyItem.reverse_deps",
					"group": "navigation"
				},
				{
					"command": "zmk.openSourceFile",
					"when": "view == targetTreeView && viewItem == propertyItem.sources",
					"group": "inline"
				},
				{
					"command": "zmk.openSourceFile",
					"when": "view == targetTreeView && viewItem == propertyItem.sources",
					"group": "navigation"
				},
				{
					"command": "zmk.revealIncludeDirInExplorer",
					"when": "view == targetTreeView && viewItem == propertyItem.include_dirs",
					"group": "navigation"
				},
				{
					"command": "zmk.openIncludeDirFolder",
					"when": "view == targetTreeView && viewItem == propertyItem.include_dirs",
					"group": "navigation"
				},
				{
					"command": "zmk.copyPropertyValue",
					"when": "view == targetTreeView && viewItem =~ /^propertyItem/",
					"group": "navigation@9"
				},
				{
					"command": "zmk.copyPropertyValue",
					"when": "view == targetTreeView && viewItem == propertyGroup",
					"group": "navigation@9"
				},
				{
					"command": "zmk.copyArgValue",
					"when": "view == argsView && viewItem == arg",
					"group": "navigation"
				},
				{
					"command": "zmk.copyArgPair",
					"when": "view == argsView && viewItem == arg",
					"group": "navigation@1"
				},
				{
					"command": "zmk.copyTargetData",
					"when": "view == targetTreeView && viewItem =~ /<target>/",
					"group": "navigation@9"
				},
				{
					"command": "zmk.revealIncludeInExplorer",
					"when": "view == cppSourceConfig && viewItem == include",
					"group": "navigation"
				},
				{
					"command": "zmk.revealIncludeInOS",
					"when": "view == cppSourceConfig && viewItem == include",
					"group": "navigation"
				},
				{
					"command": "zmk.cppSource.copyText",
					"when": "view == cppSourceConfig",
					"group": "navigation"
				},
				{
					"command": "zmk.cppSource.copyJson",
					"when": "view == cppSourceConfig",
					"group": "navigation"
				},
				{
					"command": "zmk.sourceTree.revealSourceInExplorer",
					"when": "view == sourceTreeView && viewItem == sourceTree.sourceFile",
					"group": "navigation"
				},
				{
					"command": "zmk.sourceTree.revealSourceInOS",
					"when": "view == sourceTreeView && viewItem == sourceTree.sourceFile",
					"group": "navigation"
				}
			]
		},
		"languageModelTools": [
			{
				"name": "valhalla-list-configs",
				"toolReferenceName": "listConfigs",
				"canBeReferencedInPrompt": true,
				"displayName": "list valhalla configs",
				"modelDescription": "List available valhalla build configurations",
				"userDescription": "List available valhalla build configurations in the current workspace.",
				"inputSchema": {
					"type": "object",
					"properties": {},
					"additionalProperties": false
				}
			},
			{
				"name": "valhalla-build-target",
				"toolReferenceName": "buildTarget",
				"canBeReferencedInPrompt": true,
				"displayName": "build valhalla target",
				"modelDescription": "Build files using valhalla build system using default config",
				"userDescription": "Build a valhalla target using the default configuration in the current workspace.",
				"inputSchema": {
					"type": "object",
					"properties": {
						"target": {
							"type": "string",
							"description": "build target"
						}
					}
				}
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "node build.js --prepublish && npm run bundle",
		"bundle": "node build.js",
