{
	"name": "zmk",
	"displayName": "zmk",
	"description": "Zodiac Make",
	"version": "2.0.0",
	"engines": {
		"vscode": "^1.111.0"
	},
	"categories": [
		"Other"
	],
	"publisher": "osesov",
	"repository": {
		"type": "git",
		"url": "https://github.com/osesov/zmk.git"
	},
	"activationEvents": [
		"*"
	],
	"extensionKind": [
		"workspace"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "zmk.updateBundlesInclude",
				"title": "ZMK: Update bundles Include Paths"
			},
			{
				"command": "zmk.updateCopyright",
				"title": "ZMK: Insert or update Copyright header"
			},
			{
				"command": "zmk.setConfig",
				"title": "ZMK: Set Config"
			},
			{
				"command": "zmk.setDefaultConfig",
				"title": "Select Configuration",
				"icon": "$(star-empty)"
			},
			{
				"command": "zmk.openConfig",
				"title": "Open Configuration File",
				"icon": "$(file-code)"
			},
			{
				"command": "zmk.refreshConfigTree",
				"title": "ZMK: Refresh Configurations",
				"icon": "$(refresh)"
			},
			{
				"command": "zmk.buildTarget",
				"title": "Build",
				"icon": "$(play)"
			},
			{
				"command": "zmk.setDefaultTarget",
				"title": "Set as Default",
				"icon": "$(star-empty)"
			},
			{
				"command": "zmk.resetTarget",
				"title": "Reset Target",
				"icon": "$(discard)"
			},
			{
				"command": "zmk.refreshTargetTree",
				"title": "Refresh Targets",
				"icon": "$(refresh)"
			},
			{
				"command": "zmk.toggleIncludeListView",
				"title": "Show Includes as list",
				"icon": "$(list-unordered)"
			},
			{
				"command": "zmk.toggleIncludeTreeView",
				"title": "Show Includes as tree",
				"icon": "$(list-tree)"
			},
			{
				"command": "zmk.revealIncludeInExplorer",
				"title": "Reveal in Explorer View",
				"icon": "$(file-directory)"
			},
			{
				"command": "zmk.revealIncludeInOS",
				"title": "Open Containing folder",
				"icon": "$(file-directory)"
			}
		],
		"configuration": {
			"title": "zmk",
			"properties": {
				"zmk.rootDir": {
					"type": "string",
					"default": null,
					"description": "zmk root folder."
				},
				"zmk.buildDir": {
					"type": "string",
					"default": null,
					"description": "zmk root folder."
				},
				"zmk.bundleDir": {
					"type": "string",
					"description": "zmk bundle folder location",
					"default": null
				},
				"zmk.config": {
					"type": "string",
					"default": "zodiac-pc_linux-zebra-dev",
					"description": "zmk config name."
				},
				"zmk.target": {
					"type": [
						"string",
						"null"
					],
					"default": null,
					"description": "Ninja target to build."
				},
				"zmk.nfsDir": {
					"type": [
						"string",
						"null"
					],
					"default": null,
					"description": "root of nfs image"
				},
				"zmk.excludeBundles": {
					"type": "array",
					"items": {
						"type": "string",
						"title": "bundle name to exclude"
					},
					"default": [],
					"description": "List of bundles to exclude"
				},
				"zmk.developer": {
					"type": "string",
					"default": "<<<add your name to 'zmk.developer'>>>",
					"description": "Developer name"
				},
				"zmk.copyrightComment": {
					"type": [
						"string",
						null
					],
					"default": null,
					"description": "Copyright comment template"
				},
				"zmk.disableCppToolsIntegration": {
					"type": "boolean",
					"description": "Disable C++ tools integration (include paths, defines, etc.). Use plain C++ tools configs.",
					"default": false
				},
				"zmk.includeDirs": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Extra include dirs for intellisense",
					"default": []
				},
				"zmk.defines": {
					"type": "object",
					"description": "Extra defines for intellisense",
					"additionalProperties": {
						"oneOf": [
							{
								"type": "string"
							},
							{
								"type": "null"
							}
						]
					},
					"default": {}
				},
				"zmk.compiler": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Intellisense compiler path and args",
					"default": []
				},
				"zmk.intelliSenseMode": {
					"type": "string",
					"markdownDescription": "Intellisense mode (e.g. 'gcc-x64'). See [VS Code C++ Intellisense Configuration](https://code.visualstudio.com/docs/cpp/customize-cpp-settings#_configuration-properties)",
					"default": null
				},
				"zmk.cppStandard": {
					"type": "string",
					"markdownDescription": "C++ standard (e.g. 'c++17'). See [VS Code C++ Intellisense Configuration](https://code.visualstudio.com/docs/cpp/customize-cpp-settings#_configuration-properties)",
					"default": null
				},
				"zmk.toolchain": {
					"type": "array",
					"description": "Toolchain selection rules.",
					"items": {
						"type": "object",
						"properties": {
							"pattern": {
								"type": "string",
								"description": "Pattern to match compiler name. 'cross_os[-cross_cpu[-cross_abi]]'"
							},
							"compiler": {
								"type": "array",
								"items": {
									"type": "string"
								},
								"description": "Intellisense compiler path and args"
							},
							"intelliSenseMode": {
								"type": "string",
								"description": "Intellisense mode (e.g. 'gcc-x64'). See [VS Code C++ Intellisense Configuration](https://code.visualstudio.com/docs/cpp/customize-cpp-settings#_configuration-properties)"
							},
							"cppStandard": {
								"type": "string",
								"description": "C++ standard (e.g. 'c++17'). See [VS Code C++ Intellisense Configuration](https://code.visualstudio.com/docs/cpp/customize-cpp-settings#_configuration-properties)"
							},
							"defines": {
								"type": "object",
								"description": "Defines for intellisense",
								"additionalProperties": {
									"oneOf": [
										{
											"type": "string"
										},
										{
											"type": "null"
										}
									]
								}
							},
							"includeDirs": {
								"type": "array",
								"description": "Include dirs for intellisense",
								"items": {
									"type": "string"
								},
								"default": null
							},
							"env": {
								"type": "object",
								"description": "Environment variables for intellisense",
								"additionalProperties": {
									"oneOf": [
										{
											"type": "string"
										},
										{
											"type": "null"
										}
									]
								}
							}
						}
					}
				}
			}
		},
		"taskDefinitions": [
			{
				"type": "gnb",
				"properties": {
					"label": {
						"type": "string",
						"description": "Task label"
					},
					"config": {
						"type": "string",
						"description": "gnb config (see configs/*.yaml)"
					},
					"target": {
						"type": "string",
						"description": "ninja target to build"
					},
					"gnbFlags": {
						"type": "array",
						"items": {
							"type": "string",
							"title": "gnb flag"
						},
						"description": "additional gnb flags"
					},
					"gnFlags": {
						"type": "array",
						"items": {
							"type": "string",
							"title": "gn flag"
						},
						"description": "additional gn flags"
					},
					"env": {
						"type": "object",
						"description": "Environment variables",
						"additionalProperties": {
							"oneOf": [
								{
									"type": "string"
								},
								{
									"type": "null"
								}
							]
						}
					}
				}
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "valhallaContainer",
					"title": "Valhalla build system",
					"icon": "./images/helm.svg",
					"dark": "./images/helm.svg"
				}
			]
		},
		"views": {
			"valhallaContainer": [
				{
					"id": "configTreeView",
					"name": "Configurations"
				},
				{
					"id": "targetTreeView",
					"name": "Targets"
				},
				{
					"id": "argsView",
					"name": "Args"
				},
				{
					"id": "cppSourceConfig",
					"name": "Source File Info"
				}
			]
		},
		"menus": {
			"view/title": [
				{
					"command": "zmk.refreshConfigTree",
					"when": "view == configTreeView",
					"group": "navigation"
				},
				{
					"command": "zmk.refreshTargetTree",
					"when": "view == targetTreeView",
					"group": "navigation"
				},
				{
					"command": "zmk.resetTarget",
					"when": "view == targetTreeView && zmk.targetSelected",
					"group": "navigation"
				},
				{
					"command": "zmk.toggleIncludeListView",
					"when": "view == cppSourceConfig && zmk.includeViewMode == 'tree'",
					"group": "navigation"
				},
				{
					"command": "zmk.toggleIncludeTreeView",
					"when": "view == cppSourceConfig && zmk.includeViewMode == 'list'",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "zmk.setDefaultConfig",
					"when": "view == configTreeView && viewItem == config",
					"group": "inline"
				},
				{
					"command": "zmk.setDefaultConfig",
					"when": "view == configTreeView && viewItem == config",
					"group": "navigation"
				},
				{
					"command": "zmk.openConfig",
					"when": "view == configTreeView && (viewItem == config || viewItem == defaultConfig)",
					"group": "navigation"
				},

				{
					"command": "zmk.buildTarget",
					"when": "view == targetTreeView && (viewItem == target || viewItem == currentTarget)",
					"group": "inline"
				},
				{
					"command": "zmk.buildTarget",
					"when": "view == targetTreeView && (viewItem == target || viewItem == currentTarget)",
					"group": "navigation"
				},
				{
					"command": "zmk.setDefaultTarget",
					"when": "view == targetTreeView && viewItem == target",
					"group": "inline"
				},
				{
					"command": "zmk.setDefaultTarget",
					"when": "view == targetTreeView && viewItem == target",
					"group": "navigation@2"
				},
				{
					"command": "zmk.resetTarget",
					"when": "view == targetTreeView && viewItem == currentTarget",
					"group": "inline"
				},
				{
					"command": "zmk.resetTarget",
					"when": "view == targetTreeView && viewItem == currentTarget",
					"group": "navigation@2"
				},

				{
					"command": "zmk.revealIncludeInExplorer",
					"when": "view == cppSourceConfig && viewItem == include",
					"group": "navigation"
				},
				{
					"command": "zmk.revealIncludeInOS",
					"when": "view == cppSourceConfig && viewItem == include",
					"group": "navigation"
				}

			]
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run bundle",
		"bundle": "node build.js",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"test": "npm run compile && vscode-test",
		"package": "npm i && npm run compile && vsce package",
		"lint": "eslint ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.4.0",
		"@types/shell-quote": "^1.7.5",
		"@types/vscode": "^1.110.0",
		"@typescript-eslint/parser": "^8.57.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.7.1",
		"esbuild": "^0.27.3",
		"eslint": "^10.0.3",
		"globals": "^17.4.0",
		"jiti": "^2.6.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vscode-cpptools": "^7.1.1"
	},
	"license": "0BSD",
	"dependencies": {
		"shell-quote": "^1.8.3",
		"vscode-uri": "^3.1.0"
	}
}
